{
  "name": "secure",
  "extensions": [
    "pgcrypto"
  ],
  "enums": [],
  "domains": [
    {
      "name": "short_text",
      "schema": "secure",
      "base_type": {
        "base": "text",
        "params": {}
      },
      "check": "LENGTH(VALUE) \u003c= 255"
    }
  ],
  "tables": [
    {
      "name": "documents",
      "schema": "secure",
      "comment": "User documents with row-level security",
      "columns": [
        {
          "name": "id",
          "pg_type": {
            "base": "uuid",
            "params": {}
          },
          "not_null": true,
          "default_expr": "gen_random_uuid()",
          "semantic_type_name": "id"
        },
        {
          "name": "owner_id",
          "pg_type": {
            "base": "uuid",
            "params": {}
          },
          "not_null": true,
          "semantic_type_name": "ref"
        },
        {
          "name": "title",
          "pg_type": {
            "base": "text",
            "domain_name": "short_text",
            "params": {}
          },
          "not_null": true,
          "semantic_type_name": "short_text"
        },
        {
          "name": "created_at",
          "pg_type": {
            "base": "timestamptz",
            "params": {}
          },
          "not_null": true,
          "default_expr": "now()",
          "semantic_type_name": "timestamp"
        }
      ],
      "pk": [
        "id"
      ],
      "fks": [],
      "indexes": [],
      "uniques": [],
      "checks": [],
      "exclusions": [],
      "policies": [
        {
          "name": "owners_delete",
          "type": "PERMISSIVE",
          "operation": "DELETE",
          "role": "app_user",
          "using": "owner_id = current_setting('app.user_id')::uuid"
        },
        {
          "name": "owners_insert",
          "type": "PERMISSIVE",
          "operation": "INSERT",
          "role": "app_user",
          "with_check": "owner_id = current_setting('app.user_id')::uuid"
        },
        {
          "name": "owners_read",
          "type": "PERMISSIVE",
          "operation": "SELECT",
          "role": "app_user",
          "using": "owner_id = current_setting('app.user_id')::uuid"
        },
        {
          "name": "owners_update",
          "type": "PERMISSIVE",
          "operation": "UPDATE",
          "role": "app_user",
          "using": "owner_id = current_setting('app.user_id')::uuid",
          "with_check": "owner_id = current_setting('app.user_id')::uuid"
        }
      ],
      "enable_rls": true
    }
  ],
  "pg_version": 1
}