// pgdesign testdb protocol v1
// Generated by pgdesign -- do not edit manually. Re-run: pgdesign testdb init --language go
package testdb

import (
	"bufio"
	"context"
	"crypto/rand"
	"fmt"
	"math/big"
	"net/url"
	"os"
	"regexp"
	"strconv"
	"strings"
	"testing"
	"time"

	"github.com/jackc/pgx/v5"
)

const (
	ddlPath  = "{{DDL_PATH}}"
	baseURL  = "{{BASE_URL}}"
	baseName = "{{BASE_NAME}}"
	charset  = "abcdefghijklmnopqrstuvwxyz0123456789"
)

// namePattern validates ephemeral database names.
var namePattern = regexp.MustCompile(`^(.+)_test_(\d{10,})_([a-z0-9]{8})$`)

// TestDB holds an ephemeral test database connection.
type TestDB struct {
	conn *pgx.Conn
	url  string
	name string
}

// ConnString returns the connection URL for the ephemeral database.
func (t *TestDB) ConnString() string { return t.url }

// WithRawConn calls fn with the underlying connection. The connection must not
// be retained beyond the callback's return.
func (t *TestDB) WithRawConn(fn func(*pgx.Conn) error) error { return fn(t.conn) }

// SetupTestDB creates an ephemeral database, applies DDL, and returns a connection.
// The database is automatically dropped when the test completes.
func SetupTestDB(t *testing.T) *TestDB {
	t.Helper()
	ctx := context.Background()

	name := generateName()
	validateName(name)

	connURL := os.Getenv("PGDESIGN_DB")
	if connURL == "" {
		connURL = baseURL
	}

	// Connect to maintenance DB.
	maintURL := swapDB(connURL, "postgres")
	maintConn, err := pgx.Connect(ctx, maintURL)
	if err != nil {
		t.Fatalf("pgdesign testdb: connect to maintenance DB: %v", err)
	}

	// Create the ephemeral database.
	_, err = maintConn.Exec(ctx, "CREATE DATABASE "+pgx.Identifier{name}.Sanitize())
	maintConn.Close(ctx)
	if err != nil {
		t.Fatalf("pgdesign testdb: create database: %v", err)
	}

	// Connect to the new database.
	dbURL := swapDB(connURL, name)
	conn, err := pgx.Connect(ctx, dbURL)
	if err != nil {
		dropDB(connURL, name)
		t.Fatalf("pgdesign testdb: connect to ephemeral DB: %v", err)
	}

	// Apply DDL from .sqlsplit.
	if err := applyDDL(ctx, conn); err != nil {
		conn.Close(ctx)
		dropDB(connURL, name)
		t.Fatalf("pgdesign testdb: apply DDL: %v", err)
	}

	tdb := &TestDB{conn: conn, url: dbURL, name: name}

	t.Cleanup(func() {
		conn.Close(context.Background())
		dropDB(connURL, name)
	})

	return tdb
}

// validateName panics if the name does not match the ephemeral name pattern.
func validateName(name string) {
	if !namePattern.MatchString(name) {
		panic(fmt.Sprintf("pgdesign: refusing to use database %q: does not match ephemeral name pattern", name))
	}
}

// generateName creates a unique ephemeral database name.
func generateName() string {
	suffix := randomString(8)
	name := fmt.Sprintf("%s_test_%d_%s", baseName, time.Now().Unix(), suffix)
	// Truncate base name if total exceeds PostgreSQL's 63-byte limit.
	if len(name) > 63 {
		// Fixed suffix: _test_ (6) + timestamp (10) + _ (1) + random (8) = 25
		maxBase := 63 - 25
		truncated := baseName
		if len(truncated) > maxBase {
			// Truncate at a valid UTF-8 character boundary. Walk backward
			// from maxBase while the byte is a continuation byte (0x80..0xBF)
			// to find the start of any split character, then truncate there.
			end := maxBase
			for end > 0 && truncated[end]&0xC0 == 0x80 {
				end--
			}
			truncated = truncated[:end]
		}
		name = fmt.Sprintf("%s_test_%d_%s", truncated, time.Now().Unix(), suffix)
	}
	if len(name) > 63 {
		panic(fmt.Sprintf("pgdesign testdb: generated name exceeds 63 bytes: %q (%d bytes)", name, len(name)))
	}
	return name
}

// randomString generates a cryptographically random string of length n.
func randomString(n int) string {
	charsetLen := big.NewInt(int64(len(charset)))
	var b strings.Builder
	b.Grow(n)
	for i := 0; i < n; i++ {
		idx, err := rand.Int(rand.Reader, charsetLen)
		if err != nil {
			panic(fmt.Sprintf("crypto/rand: %v", err))
		}
		b.WriteByte(charset[idx.Int64()])
	}
	return b.String()
}

// swapDB rewrites a PostgreSQL connection URL to target a different database.
func swapDB(connURL, dbName string) string {
	u, err := url.Parse(connURL)
	if err != nil {
		panic(fmt.Sprintf("pgdesign testdb: invalid connection URL: %v", err))
	}
	u.Path = "/" + dbName
	return u.String()
}

// applyDDL reads the .sqlsplit file and executes each SQL statement.
func applyDDL(ctx context.Context, conn *pgx.Conn) error {
	data, err := os.ReadFile(ddlPath)
	if err != nil {
		return fmt.Errorf("read %s: %w", ddlPath, err)
	}

	stmts, err := parseSQLSplit(data)
	if err != nil {
		return fmt.Errorf("parse %s: %w", ddlPath, err)
	}

	for i, stmt := range stmts {
		if _, err := conn.Exec(ctx, stmt); err != nil {
			preview := ""
			for _, line := range strings.Split(stmt, "\n") {
				if trimmed := strings.TrimSpace(line); trimmed != "" {
					preview = trimmed
					break
				}
			}
			if len(preview) > 120 {
				preview = preview[:120] + "..."
			}
			return fmt.Errorf("statement %d failed (%s): %w", i+1, preview, err)
		}
	}
	return nil
}

// parseSQLSplit decodes the .sqlsplit format: count line, then (byte-length
// line, payload bytes, trailing newline) per statement.
func parseSQLSplit(data []byte) ([]string, error) {
	scanner := bufio.NewScanner(strings.NewReader(string(data)))

	// Read statement count.
	if !scanner.Scan() {
		return nil, fmt.Errorf("missing statement count line")
	}
	count, err := strconv.Atoi(scanner.Text())
	if err != nil {
		return nil, fmt.Errorf("invalid statement count: %w", err)
	}

	// Track position in raw data after the count line.
	pos := len(scanner.Text()) + 1 // +1 for the newline
	raw := data

	stmts := make([]string, 0, count)
	for i := 0; i < count; i++ {
		// Read the byte-length line.
		nlIdx := indexOf(raw[pos:], '\n')
		if nlIdx < 0 {
			return nil, fmt.Errorf("statement %d: missing length line", i)
		}
		length, err := strconv.Atoi(string(raw[pos : pos+nlIdx]))
		if err != nil {
			return nil, fmt.Errorf("statement %d: invalid byte length: %w", i, err)
		}
		pos += nlIdx + 1

		// Read exactly `length` bytes.
		if pos+length > len(raw) {
			return nil, fmt.Errorf("statement %d: expected %d bytes but only %d remain", i, length, len(raw)-pos)
		}
		stmts = append(stmts, string(raw[pos:pos+length]))
		pos += length

		// Skip trailing newline.
		if pos < len(raw) && raw[pos] == '\n' {
			pos++
		}
	}
	return stmts, nil
}

func indexOf(data []byte, b byte) int {
	for i, c := range data {
		if c == b {
			return i
		}
	}
	return -1
}

// dropDB terminates connections and drops the named database.
func dropDB(connURL, name string) {
	validateName(name)
	ctx := context.Background()
	maintURL := swapDB(connURL, "postgres")
	conn, err := pgx.Connect(ctx, maintURL)
	if err != nil {
		return
	}
	defer conn.Close(ctx)

	_, _ = conn.Exec(ctx,
		"SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = $1 AND pid != pg_backend_pid()",
		name,
	)
	_, _ = conn.Exec(ctx, "DROP DATABASE IF EXISTS "+pgx.Identifier{name}.Sanitize())
}
