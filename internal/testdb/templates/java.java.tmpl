public class TestDB implements BeforeAllCallback, AfterAllCallback {
    private static final String DDL_PATH = "{{DDL_PATH}}";
    private static final String BASE_URL = "{{BASE_URL}}";
    private static final String BASE_NAME = "{{BASE_NAME}}";
    private static final String CHARSET = "abcdefghijklmnopqrstuvwxyz0123456789";
    private static final int RAND_LEN = 8;
    private static final int MAX_NAME_LEN = 63;
    // Fixed suffix: _test_ (6) + timestamp (10) + _ (1) + random (8) = 25
    private static final int SUFFIX_LEN = 25;
    private static final SecureRandom RANDOM = new SecureRandom();

    private String name;
    private String url;
    private String baseUrl;
    private Connection connection;

    /** Returns the JDBC connection to the ephemeral database. */
    public Connection getConnection() { return connection; }
    /** Returns the JDBC URL of the ephemeral database. */
    public String getUrl() { return url; }
    /** Returns the name of the ephemeral database. */
