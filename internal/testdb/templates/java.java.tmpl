    @Override
    public void beforeAll(ExtensionContext ctx) throws Exception {
        name = generateName();
        baseUrl = System.getenv("PGDESIGN_DB");
        if (baseUrl == null || baseUrl.isEmpty()) {
            baseUrl = BASE_URL;
        }

        // Connect to maintenance DB and create the ephemeral database.
        String maintUrl = swapDB(baseUrl, "postgres");
        try (Connection maintConn = DriverManager.getConnection(toJdbcUrl(maintUrl))) {
            maintConn.setAutoCommit(true);
            try (Statement stmt = maintConn.createStatement()) {
                stmt.execute("CREATE DATABASE " + escapeIdentifier(name));
            }
        }

        // Connect to the new database and apply DDL.
        url = toJdbcUrl(swapDB(baseUrl, name));
        connection = DriverManager.getConnection(url);
        try {
            applyDDL(connection);
        } catch (Exception e) {
            connection.close();
            dropDB(baseUrl, name);
            throw e;
