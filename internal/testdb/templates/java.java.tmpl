    private static String generateName() {
        String suffix = randomString(RAND_LEN);
        long ts = System.currentTimeMillis() / 1000;
        int maxBase = MAX_NAME_LEN - SUFFIX_LEN;
        String base = BASE_NAME;
        if (base.getBytes(java.nio.charset.StandardCharsets.UTF_8).length > maxBase) {
            base = base.substring(0, maxBase);
        }
        String result = base + "_test_" + ts + "_" + suffix;
        if (result.getBytes(java.nio.charset.StandardCharsets.UTF_8).length > MAX_NAME_LEN) {
            throw new IllegalStateException(
                "pgdesign testdb: database name exceeds 63 bytes: " + result);
        }
        return result;
    }

    private static String randomString(int n) {
        StringBuilder sb = new StringBuilder(n);
        for (int i = 0; i < n; i++) {
            sb.append(CHARSET.charAt(RANDOM.nextInt(CHARSET.length())));
        }
        return sb.toString();
    }

    private static String swapDB(String connUrl, String dbName) {
        URI uri = URI.create(connUrl);
        try {
            return new URI(
                uri.getScheme(), uri.getUserInfo(), uri.getHost(),
                uri.getPort(), "/" + dbName, uri.getQuery(), null
            ).toString();
        } catch (Exception e) {
            throw new IllegalArgumentException(
                "pgdesign testdb: invalid connection URL: " + e.getMessage(), e);
        }
    }

    /**
     * Convert a postgres:// URL to a jdbc:postgresql:// URL.
     * JDBC requires the jdbc: prefix; pg connection URLs typically use postgres://.
     */
    private static String toJdbcUrl(String pgUrl) {
        if (pgUrl.startsWith("jdbc:")) {
            return pgUrl;
        }
        if (pgUrl.startsWith("postgres://")) {
            return "jdbc:postgresql://" + pgUrl.substring("postgres://".length());
        }
        if (pgUrl.startsWith("postgresql://")) {
            return "jdbc:postgresql://" + pgUrl.substring("postgresql://".length());
        }
        return "jdbc:" + pgUrl;
    }

    /**
     * Escape a PostgreSQL identifier by double-quoting it.
     * Internal double quotes are doubled per SQL standard.
     */
    private static String escapeIdentifier(String name) {
        return "\"" + name.replace("\"", "\"\"") + "\"";
    }

    private static void applyDDL(Connection conn) throws IOException, SQLException {
        String data = new String(
            Files.readAllBytes(Paths.get(DDL_PATH)),
            java.nio.charset.StandardCharsets.UTF_8
        );
        List<String> stmts = parseJsonStringArray(data);
        try (Statement st = conn.createStatement()) {
            for (int i = 0; i < stmts.size(); i++) {
                try {
                    st.execute(stmts.get(i));
                } catch (SQLException e) {
                    throw new SQLException(
                        "pgdesign testdb: statement " + (i + 1) + " failed: " + e.getMessage(), e);
                }
            }
        }
    }

    private static void dropDB(String connUrl, String dbName) {
        String maintUrl = swapDB(connUrl, "postgres");
        try (Connection conn = DriverManager.getConnection(toJdbcUrl(maintUrl))) {
            conn.setAutoCommit(true);
            try (Statement stmt = conn.createStatement()) {
                stmt.execute(
                    "SELECT pg_terminate_backend(pid) FROM pg_stat_activity "
                    + "WHERE datname = '" + dbName.replace("'", "''") + "' "
                    + "AND pid != pg_backend_pid()");
            }
            try (Statement stmt = conn.createStatement()) {
                stmt.execute("DROP DATABASE IF EXISTS " + escapeIdentifier(dbName));
            }
        } catch (SQLException e) {
            // Best-effort cleanup.
        }
    }

    /**
     * Minimal JSON string array parser. Avoids external dependencies.
     * Expects input of the form: ["stmt1", "stmt2", ...]
     */
    private static List<String> parseJsonStringArray(String json) {
        List<String> result = new ArrayList<>();
        json = json.trim();
        if (!json.startsWith("[") || !json.endsWith("]")) {
            throw new IllegalArgumentException("pgdesign testdb: expected JSON array in " + DDL_PATH);
        }
        json = json.substring(1, json.length() - 1).trim();
        if (json.isEmpty()) {
            return result;
        }

        int i = 0;
        while (i < json.length()) {
            // Skip whitespace and commas.
            while (i < json.length() && (json.charAt(i) == ',' || Character.isWhitespace(json.charAt(i)))) {
                i++;
            }
            if (i >= json.length()) break;
            if (json.charAt(i) != '"') {
                throw new IllegalArgumentException(
                    "pgdesign testdb: expected string in JSON array at position " + i);
            }
            i++; // skip opening quote
            StringBuilder sb = new StringBuilder();
            while (i < json.length()) {
                char c = json.charAt(i);
                if (c == '\\' && i + 1 < json.length()) {
                    char next = json.charAt(i + 1);
                    switch (next) {
                        case '"': sb.append('"'); break;
                        case '\\': sb.append('\\'); break;
                        case '/': sb.append('/'); break;
                        case 'n': sb.append('\n'); break;
                        case 'r': sb.append('\r'); break;
                        case 't': sb.append('\t'); break;
                        case 'b': sb.append('\b'); break;
                        case 'f': sb.append('\f'); break;
                        case 'u':
                            if (i + 5 < json.length()) {
                                String hex = json.substring(i + 2, i + 6);
                                sb.append((char) Integer.parseInt(hex, 16));
                                i += 4; // extra advance for \uXXXX
                            }
                            break;
                        default: sb.append(next); break;
                    }
                    i += 2;
                } else if (c == '"') {
                    i++; // skip closing quote
                    break;
                } else {
                    sb.append(c);
                    i++;
                }
            }
            result.add(sb.toString());
        }
        return result;
    }
