package pgdesign;

import java.io.IOException;
import java.net.URI;
import java.nio.file.Files;
import java.nio.file.Paths;
import java.security.SecureRandom;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.SQLException;
import java.sql.Statement;
import java.util.ArrayList;
import java.util.List;
import java.util.function.Consumer;
import java.util.regex.Pattern;
import org.junit.jupiter.api.extension.AfterAllCallback;
import org.junit.jupiter.api.extension.BeforeAllCallback;
import org.junit.jupiter.api.extension.ExtensionContext;

/**
 * JUnit 5 extension that creates an ephemeral PostgreSQL database for testing.
 *
 * <p>Usage:
 * <pre>
 * {@literal @}RegisterExtension
 * static final TestDB db = new TestDB();
 *
 * {@literal @}Test
 * void example() throws SQLException {
 *     db.withRawConnection(conn -> {
 *         // ...
 *     });
 * }
 * </pre>
 */
public class TestDB implements BeforeAllCallback, AfterAllCallback {
    private static final String DDL_PATH = "{{DDL_PATH}}";
    private static final String BASE_URL = "{{BASE_URL}}";
    private static final String BASE_NAME = "{{BASE_NAME}}";
    private static final String CHARSET = "abcdefghijklmnopqrstuvwxyz0123456789";
    private static final int RAND_LEN = 8;
    private static final int MAX_NAME_LEN = 63;
    // Fixed suffix: _test_ (6) + timestamp (10) + _ (1) + random (8) = 25
    private static final int SUFFIX_LEN = 25;
    private static final SecureRandom RANDOM = new SecureRandom();
    private static final Pattern NAME_PATTERN = Pattern.compile("^(.+)_test_(\\d{10,})_([a-z0-9]{8})$");

    private String name;
    private String url;
    private String baseUrl;
    private Connection connection;

    /** Returns the JDBC connection URL for ORM integration. */
    public String getConnectionString() { return url; }

    /** Executes a callback with the raw JDBC connection. */
    public void withRawConnection(Consumer<Connection> callback) { callback.accept(connection); }

    private static void validateName(String name) {
        if (!NAME_PATTERN.matcher(name).matches()) {
            throw new IllegalStateException(
                "pgdesign: refusing to use database \"" + name + "\": does not match ephemeral name pattern");
        }
    }

    @Override
    public void beforeAll(ExtensionContext ctx) throws Exception {
        name = generateName();
        validateName(name);
        baseUrl = System.getenv("PGDESIGN_DB");
        if (baseUrl == null || baseUrl.isEmpty()) {
            baseUrl = BASE_URL;
        }

        // Connect to maintenance DB and create the ephemeral database.
        String maintUrl = swapDB(baseUrl, "postgres");
        try (Connection maintConn = DriverManager.getConnection(toJdbcUrl(maintUrl))) {
            maintConn.setAutoCommit(true);
            try (Statement stmt = maintConn.createStatement()) {
                stmt.execute("CREATE DATABASE " + escapeIdentifier(name));
            }
        }

        // Connect to the new database and apply DDL.
        url = toJdbcUrl(swapDB(baseUrl, name));
        connection = DriverManager.getConnection(url);
        try {
            applyDDL(connection);
        } catch (Exception e) {
            connection.close();
            dropDB(baseUrl, name);
            throw e;
        }
    }

    @Override
    public void afterAll(ExtensionContext ctx) {
        if (connection != null) {
            try {
                connection.close();
            } catch (SQLException e) {
                // Best-effort cleanup.
            }
        }
        if (name != null && baseUrl != null) {
            dropDB(baseUrl, name);
        }
    }

    private static String generateName() {
        String suffix = randomString(RAND_LEN);
        long ts = System.currentTimeMillis() / 1000;
        int maxBase = MAX_NAME_LEN - SUFFIX_LEN;
        String base = BASE_NAME;
        byte[] baseBytes = base.getBytes(java.nio.charset.StandardCharsets.UTF_8);
        if (baseBytes.length > maxBase) {
            // Truncate at a valid UTF-8 character boundary. Walk backward
            // from maxBase while the byte is a continuation byte (0x80..0xBF)
            // to find the start of any split character, then truncate there.
            int end = maxBase;
            while (end > 0 && (baseBytes[end] & 0xC0) == 0x80) {
                end--;
            }
            base = new String(baseBytes, 0, end, java.nio.charset.StandardCharsets.UTF_8);
        }
        String result = base + "_test_" + ts + "_" + suffix;
        if (result.getBytes(java.nio.charset.StandardCharsets.UTF_8).length > MAX_NAME_LEN) {
            throw new IllegalStateException(
                "pgdesign testdb: database name exceeds 63 bytes: " + result);
        }
        return result;
    }

    private static String randomString(int n) {
        StringBuilder sb = new StringBuilder(n);
        for (int i = 0; i < n; i++) {
            sb.append(CHARSET.charAt(RANDOM.nextInt(CHARSET.length())));
        }
        return sb.toString();
    }

    private static String swapDB(String connUrl, String dbName) {
        URI uri = URI.create(connUrl);
        try {
            return new URI(
                uri.getScheme(), uri.getUserInfo(), uri.getHost(),
                uri.getPort(), "/" + dbName, uri.getQuery(), null
            ).toString();
        } catch (Exception e) {
            throw new IllegalArgumentException(
                "pgdesign testdb: invalid connection URL: " + e.getMessage(), e);
        }
    }

    /**
     * Convert a postgres:// URL to a jdbc:postgresql:// URL.
     * JDBC requires the jdbc: prefix; pg connection URLs typically use postgres://.
     */
    private static String toJdbcUrl(String pgUrl) {
        if (pgUrl.startsWith("jdbc:")) {
            return pgUrl;
        }
        if (pgUrl.startsWith("postgres://")) {
            return "jdbc:postgresql://" + pgUrl.substring("postgres://".length());
        }
        if (pgUrl.startsWith("postgresql://")) {
            return "jdbc:postgresql://" + pgUrl.substring("postgresql://".length());
        }
        return "jdbc:" + pgUrl;
    }

    /**
     * Escape a PostgreSQL identifier by double-quoting it.
     * Internal double quotes are doubled per SQL standard.
     */
    private static String escapeIdentifier(String name) {
        return "\"" + name.replace("\"", "\"\"") + "\"";
    }

    /**
     * Parse the .sqlsplit format: count line, then (byte-length, payload, newline) per stmt.
     */
    private static List<String> parseSQLSplit(byte[] data) {
        int pos = 0;

        // Read statement count line.
        int nl = indexOfByte(data, (byte) '\n', pos);
        if (nl < 0) {
            throw new IllegalArgumentException("pgdesign testdb: missing statement count line in " + DDL_PATH);
        }
        int count = Integer.parseInt(new String(data, pos, nl - pos, java.nio.charset.StandardCharsets.UTF_8).trim());
        pos = nl + 1;

        List<String> stmts = new ArrayList<>(count);
        for (int i = 0; i < count; i++) {
            // Read byte-length line.
            nl = indexOfByte(data, (byte) '\n', pos);
            if (nl < 0) {
                throw new IllegalArgumentException(
                    "pgdesign testdb: statement " + i + ": missing length line in " + DDL_PATH);
            }
            int length = Integer.parseInt(
                new String(data, pos, nl - pos, java.nio.charset.StandardCharsets.UTF_8).trim());
            pos = nl + 1;

            // Read exactly `length` bytes.
            stmts.add(new String(data, pos, length, java.nio.charset.StandardCharsets.UTF_8));
            pos += length;

            // Skip trailing newline.
            if (pos < data.length && data[pos] == '\n') {
                pos++;
            }
        }
        return stmts;
    }

    private static int indexOfByte(byte[] data, byte b, int from) {
        for (int i = from; i < data.length; i++) {
            if (data[i] == b) return i;
        }
        return -1;
    }

    private static void applyDDL(Connection conn) throws IOException, SQLException {
        byte[] data = Files.readAllBytes(Paths.get(DDL_PATH));
        List<String> stmts = parseSQLSplit(data);
        try (Statement st = conn.createStatement()) {
            for (int i = 0; i < stmts.size(); i++) {
                try {
                    st.execute(stmts.get(i));
                } catch (SQLException e) {
                    String preview = "";
                    for (String line : stmts.get(i).split("\n")) {
                        if (!line.trim().isEmpty()) {
                            preview = line.trim();
                            break;
                        }
                    }
                    if (preview.length() > 120) {
                        preview = preview.substring(0, 120) + "...";
                    }
                    throw new SQLException(
                        "pgdesign testdb: statement " + (i + 1) + " failed (" + preview + "): " + e.getMessage(), e);
                }
            }
        }
    }

    private static void dropDB(String connUrl, String dbName) {
        validateName(dbName);
        String maintUrl = swapDB(connUrl, "postgres");
        try (Connection conn = DriverManager.getConnection(toJdbcUrl(maintUrl))) {
            conn.setAutoCommit(true);
            try (java.sql.PreparedStatement ps = conn.prepareStatement(
                    "SELECT pg_terminate_backend(pid) FROM pg_stat_activity "
                    + "WHERE datname = ? AND pid != pg_backend_pid()")) {
                ps.setString(1, dbName);
                ps.execute();
            }
            try (Statement stmt = conn.createStatement()) {
                stmt.execute("DROP DATABASE IF EXISTS " + escapeIdentifier(dbName));
            }
        } catch (SQLException e) {
            // Best-effort cleanup.
        }
    }
}
