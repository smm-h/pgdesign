// pgdesign testdb protocol v1
// Generated by pgdesign -- do not edit manually. Re-run: pgdesign testdb init --language zig
const std = @import("std");
const pg = @import("pg");

const Io = std.Io;

const DDL_PATH = "{{DDL_PATH}}";
const BASE_URL = "{{BASE_URL}}";
const BASE_NAME = "{{BASE_NAME}}";
const CHARSET = "abcdefghijklmnopqrstuvwxyz0123456789";
const RAND_LEN = 8;
const MAX_NAME_LEN = 63;
// Fixed suffix: _test_ (6) + timestamp (10) + _ (1) + random (8) = 25
const SUFFIX_LEN = 25;

pub const TestDB = struct {
    conn: pg.Conn,
    url: []const u8,
    allocator: std.mem.Allocator,
    io: Io,
    // Tracks allocated strings for cleanup.
    name_buf: []u8,
    url_buf: []u8,

    /// Return the connection URL for ORM integration.
    pub fn connString(self: *const TestDB) []const u8 {
        return self.url;
    }

    /// Execute a callback with the raw pg connection.
    pub fn withRawConn(self: *TestDB, comptime callback: fn (*pg.Conn) anyerror!void) !void {
        try callback(&self.conn);
    }

    /// Create an ephemeral test database, apply DDL, and return a connection.
    pub fn setup(io: Io, allocator: std.mem.Allocator) !TestDB {
        const name = try generateName(allocator);
        errdefer allocator.free(name);
        validateName(name);

        const base_url = std.posix.getenv("PGDESIGN_DB") orelse BASE_URL;

        // Connect to maintenance DB and create the ephemeral database.
        const maint_url = try swapDB(allocator, base_url, "postgres");
        defer allocator.free(maint_url);

        const maint_uri = try std.Uri.parse(maint_url);
        var maint_conn = try pg.Conn.openAndAuthUri(io, allocator, maint_uri);
        defer maint_conn.deinit();

        // Build CREATE DATABASE statement with escaped identifier.
        const create_sql = try escapeIdentifierFmt(allocator, "CREATE DATABASE ", name, "");
        defer allocator.free(create_sql);
        _ = maint_conn.exec(create_sql, .{}) catch |err| {
            std.log.err("pgdesign testdb: create database failed: {}", .{err});
            return err;
        };

        // Connect to the new database and apply DDL.
        const db_url = try swapDB(allocator, base_url, name);
        errdefer allocator.free(db_url);

        const db_uri = try std.Uri.parse(db_url);
        var conn = try pg.Conn.openAndAuthUri(io, allocator, db_uri);
        errdefer {
            conn.deinit();
            dropDB(io, allocator, base_url, name);
        }

        applyDDL(&conn, allocator) catch |err| {
            conn.deinit();
            dropDB(io, allocator, base_url, name);
            return err;
        };

        return TestDB{
            .conn = conn,
            .url = db_url,
            .allocator = allocator,
            .io = io,
            .name_buf = name,
            .url_buf = db_url,
        };
    }

    /// Drop the ephemeral database and free resources.
    pub fn teardown(self: *TestDB) void {
        self.conn.deinit();

        const base_url = std.posix.getenv("PGDESIGN_DB") orelse BASE_URL;
        validateName(self.name_buf);
        dropDB(self.io, self.allocator, base_url, self.name_buf);

        self.allocator.free(self.url_buf);
        self.allocator.free(self.name_buf);
        self.* = undefined;
    }
};

/// Validate that name matches the ephemeral pattern: {base}_test_{digits}_[a-z0-9]{8}
/// Zig has no stdlib regex, so this validates structurally.
fn validateName(name: []const u8) void {
    // Find "_test_" in the name.
    const marker = "_test_";
    const marker_pos = std.mem.indexOf(u8, name, marker) orelse
        @panic("pgdesign: refusing to use database: does not contain '_test_'");

    // After "_test_", expect 10+ digits, then "_", then 8 lowercase alphanumeric.
    const after_marker = name[marker_pos + marker.len ..];
    // Count digits.
    var digit_count: usize = 0;
    while (digit_count < after_marker.len and after_marker[digit_count] >= '0' and after_marker[digit_count] <= '9') {
        digit_count += 1;
    }
    if (digit_count < 10)
        @panic("pgdesign: refusing to use database: timestamp too short");

    // Expect underscore after digits.
    if (digit_count >= after_marker.len or after_marker[digit_count] != '_')
        @panic("pgdesign: refusing to use database: missing underscore after timestamp");

    // Expect exactly 8 lowercase alphanumeric characters after the underscore.
    const suffix = after_marker[digit_count + 1 ..];
    if (suffix.len != 8)
        @panic("pgdesign: refusing to use database: random suffix is not 8 characters");

    for (suffix) |c| {
        const valid = (c >= 'a' and c <= 'z') or (c >= '0' and c <= '9');
        if (!valid)
            @panic("pgdesign: refusing to use database: random suffix contains invalid character");
    }
}

/// Generate a unique ephemeral database name.
fn generateName(allocator: std.mem.Allocator) ![]u8 {
    var suffix: [RAND_LEN]u8 = undefined;
    std.crypto.random.bytes(&suffix);
    for (&suffix) |*b| {
        // Rejection sampling: discard bytes >= 252 (largest multiple of 36 below 256)
        // to eliminate modulo bias.
        while (b.* >= 252) {
            std.crypto.random.bytes(b[0..1]);
        }
        b.* = CHARSET[b.* % CHARSET.len];
    }

    // Get wall-clock epoch seconds via CLOCK_REALTIME.
    const ts_spec = std.posix.clock_gettime(.REALTIME) catch {
        return error.ClockUnavailable;
    };
    const ts: u64 = @intCast(ts_spec.sec);
    const max_base = MAX_NAME_LEN - SUFFIX_LEN;

    var base: []const u8 = BASE_NAME;
    if (base.len > max_base) {
        // Truncate at a valid UTF-8 character boundary. Walk backward
        // from max_base while the byte is a continuation byte (0x80..0xBF)
        // to find the start of any split character, then truncate there.
        var end = max_base;
        while (end > 0 and (base[end] & 0xC0) == 0x80) {
            end -= 1;
        }
        base = base[0..end];
    }

    const name = try std.fmt.allocPrint(allocator, "{s}_test_{d}_{s}", .{ base, ts, suffix[0..] });

    if (name.len > MAX_NAME_LEN) {
        allocator.free(name);
        return error.NameTooLong;
    }

    return name;
}

/// Rewrite a PostgreSQL connection URL to target a different database.
/// Assumes URL format: postgres://[userinfo@]host[:port]/dbname[?params]
fn swapDB(allocator: std.mem.Allocator, conn_url: []const u8, db_name: []const u8) ![]u8 {
    // Find the path component (after host:port, before query).
    // Look for the third slash (scheme://host/path).
    var slash_count: usize = 0;
    var path_start: usize = 0;
    for (conn_url, 0..) |c, i| {
        if (c == '/') {
            slash_count += 1;
            if (slash_count == 3) {
                path_start = i;
                break;
            }
        }
    }
    if (slash_count < 3) {
        return error.InvalidUrl;
    }

    // Find query string start.
    var path_end: usize = conn_url.len;
    for (conn_url[path_start..], path_start..) |c, i| {
        if (c == '?') {
            path_end = i;
            break;
        }
    }

    // Reconstruct: prefix + / + db_name + query
    const prefix = conn_url[0..path_start];
    const query = conn_url[path_end..];
    return try std.fmt.allocPrint(allocator, "{s}/{s}{s}", .{ prefix, db_name, query });
}

/// Parse the .sqlsplit format: count line, then (byte-length, payload, newline) per stmt.
fn parseSQLSplit(allocator: std.mem.Allocator, data: []const u8) ![]const []const u8 {
    var pos: usize = 0;

    // Read statement count line.
    const count_nl = std.mem.indexOfScalarPos(u8, data, pos, '\n') orelse
        return error.MissingCountLine;
    const count = try std.fmt.parseInt(usize, data[pos..count_nl], 10);
    pos = count_nl + 1;

    const stmts = try allocator.alloc([]const u8, count);
    for (stmts, 0..) |*stmt, i| {
        _ = i;
        // Read byte-length line.
        const len_nl = std.mem.indexOfScalarPos(u8, data, pos, '\n') orelse
            return error.MissingLengthLine;
        const length = try std.fmt.parseInt(usize, data[pos..len_nl], 10);
        pos = len_nl + 1;

        // Read exactly `length` bytes.
        if (pos + length > data.len) return error.TruncatedPayload;
        stmt.* = data[pos .. pos + length];
        pos += length;

        // Skip trailing newline.
        if (pos < data.len and data[pos] == '\n') {
            pos += 1;
        }
    }

    return stmts;
}

/// Read the .sqlsplit file and execute each SQL statement.
fn applyDDL(conn: *pg.Conn, allocator: std.mem.Allocator) !void {
    const data = try std.fs.cwd().readFileAlloc(allocator, DDL_PATH, std.math.maxInt(usize));
    defer allocator.free(data);

    const stmts = try parseSQLSplit(allocator, data);
    defer allocator.free(stmts);

    for (stmts, 0..) |stmt, i| {
        _ = conn.exec(stmt, .{}) catch |err| {
            // Extract first non-empty line for preview.
            var preview: []const u8 = "";
            var line_start: usize = 0;
            for (stmt, 0..) |c, j| {
                if (c == '\n') {
                    const line = std.mem.trim(u8, stmt[line_start..j], " \t\r");
                    if (line.len > 0) {
                        preview = if (line.len > 120) line[0..120] else line;
                        break;
                    }
                    line_start = j + 1;
                }
            }
            if (preview.len == 0) {
                // No newline found or all lines before first newline were empty; use whole stmt trimmed.
                const trimmed = std.mem.trim(u8, stmt[line_start..], " \t\r\n");
                preview = if (trimmed.len > 120) trimmed[0..120] else trimmed;
            }
            const ellipsis: []const u8 = if (preview.len >= 120) "..." else "";
            std.log.err("pgdesign testdb: statement {d} failed ({s}{s}): {}", .{ i + 1, preview, ellipsis, err });
            return err;
        };
    }
}

/// Terminate connections and drop the named database. Best-effort.
fn dropDB(io: Io, allocator: std.mem.Allocator, base_url: []const u8, name: []const u8) void {
    const maint_url = swapDB(allocator, base_url, "postgres") catch return;
    defer allocator.free(maint_url);

    const maint_uri = std.Uri.parse(maint_url) catch return;
    var conn = pg.Conn.openAndAuthUri(io, allocator, maint_uri) catch return;
    defer conn.deinit();

    // Terminate other connections.
    const result = conn.query(
        "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = $1 AND pid != pg_backend_pid()",
        .{name},
    ) catch null;
    if (result) |r| r.deinit();

    // Drop the database.
    const drop_sql = escapeIdentifierFmt(allocator, "DROP DATABASE IF EXISTS ", name, "") catch return;
    defer allocator.free(drop_sql);
    _ = conn.exec(drop_sql, .{}) catch {};
}

/// Build a SQL statement with a double-quoted identifier.
/// Returns: prefix + "name" + suffix (with internal double quotes escaped).
fn escapeIdentifierFmt(allocator: std.mem.Allocator, prefix: []const u8, name: []const u8, suffix: []const u8) ![]u8 {
    // Count double quotes in name for allocation.
    var dq_count: usize = 0;
    for (name) |c| {
        if (c == '"') dq_count += 1;
    }

    const total = prefix.len + 1 + name.len + dq_count + 1 + suffix.len;
    const buf = try allocator.alloc(u8, total);
    var pos: usize = 0;

    @memcpy(buf[pos .. pos + prefix.len], prefix);
    pos += prefix.len;

    buf[pos] = '"';
    pos += 1;

    for (name) |c| {
        if (c == '"') {
            buf[pos] = '"';
            pos += 1;
        }
        buf[pos] = c;
        pos += 1;
    }

    buf[pos] = '"';
    pos += 1;

    @memcpy(buf[pos .. pos + suffix.len], suffix);
    pos += suffix.len;

    return buf[0..pos];
}

