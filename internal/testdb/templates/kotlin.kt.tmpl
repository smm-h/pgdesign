// pgdesign testdb protocol v1
// Generated by pgdesign -- do not edit manually. Re-run: pgdesign testdb init --language kotlin
package pgdesign

import java.net.URI
import java.nio.charset.StandardCharsets
import java.nio.file.Files
import java.nio.file.Paths
import java.security.SecureRandom
import java.sql.Connection
import java.sql.DriverManager
import org.junit.jupiter.api.extension.AfterAllCallback
import org.junit.jupiter.api.extension.BeforeAllCallback
import org.junit.jupiter.api.extension.ExtensionContext

/**
 * JUnit 5 extension that creates an ephemeral PostgreSQL database for testing.
 *
 * Usage:
 * ```kotlin
 * class MyTest {
 *     companion object {
 *         @JvmField
 *         @RegisterExtension
 *         val db = TestDB()
 *     }
 *
 *     @Test
 *     fun example() {
 *         db.withRawConnection { conn ->
 *             // ...
 *         }
 *     }
 * }
 * ```
 */
class TestDB : BeforeAllCallback, AfterAllCallback {
    private var connection: Connection? = null
    private var url: String? = null
    private var name: String? = null
    private var baseUrl: String? = null

    /** Returns the JDBC connection URL for ORM integration. */
    fun connectionString(): String = url ?: error("pgdesign testdb: not initialized")

    /** Executes a block with the raw JDBC connection. */
    fun withRawConnection(block: (Connection) -> Unit) {
        block(connection ?: error("pgdesign testdb: not initialized"))
    }

    override fun beforeAll(ctx: ExtensionContext) {
        val generatedName = generateName()
        validateName(generatedName)
        name = generatedName

        val envUrl = System.getenv("PGDESIGN_DB")
        val resolvedBaseUrl = if (envUrl.isNullOrEmpty()) BASE_URL else envUrl
        baseUrl = resolvedBaseUrl

        // Connect to maintenance DB and create the ephemeral database.
        val maintUrl = swapDB(resolvedBaseUrl, "postgres")
        DriverManager.getConnection(toJdbcUrl(maintUrl)).use { maintConn ->
            maintConn.autoCommit = true
            maintConn.createStatement().use { stmt ->
                stmt.execute("CREATE DATABASE ${escapeIdentifier(generatedName)}")
            }
        }

        // Connect to the new database and apply DDL.
        val dbUrl = toJdbcUrl(swapDB(resolvedBaseUrl, generatedName))
        url = dbUrl
        val conn = DriverManager.getConnection(dbUrl)
        try {
            applyDDL(conn)
            connection = conn
        } catch (e: Exception) {
            conn.close()
            dropDB(resolvedBaseUrl, generatedName)
            throw e
        }
    }

    override fun afterAll(ctx: ExtensionContext) {
        connection?.runCatching { close() }
        val n = name
        val base = baseUrl
        if (n != null && base != null) {
            dropDB(base, n)
        }
    }

    companion object {
        private const val DDL_PATH = "{{DDL_PATH}}"
        private const val BASE_URL = "{{BASE_URL}}"
        private const val BASE_NAME = "{{BASE_NAME}}"
        private const val CHARSET = "abcdefghijklmnopqrstuvwxyz0123456789"
        private const val RAND_LEN = 8
        private const val MAX_NAME_LEN = 63
        // Fixed suffix: _test_ (6) + timestamp (10) + _ (1) + random (8) = 25
        private const val SUFFIX_LEN = 25
        private val RANDOM = SecureRandom()
        private val NAME_PATTERN = Regex("^(.+)_test_(\\d{10,})_([a-z0-9]{8})$")

        private fun validateName(name: String) {
            check(NAME_PATTERN.matches(name)) {
                "pgdesign: refusing to use database \"$name\": does not match ephemeral name pattern"
            }
        }

        private fun generateName(): String {
            val suffix = randomString(RAND_LEN)
            val ts = System.currentTimeMillis() / 1000
            val maxBase = MAX_NAME_LEN - SUFFIX_LEN
            var base = BASE_NAME
            val baseBytes = base.toByteArray(StandardCharsets.UTF_8)
            if (baseBytes.size > maxBase) {
                // Truncate at a valid UTF-8 character boundary. Walk backward
                // from maxBase while the byte is a continuation byte (0x80..0xBF)
                // to find the start of any split character, then truncate there.
                var end = maxBase
                while (end > 0 && (baseBytes[end].toInt() and 0xC0) == 0x80) {
                    end--
                }
                base = String(baseBytes, 0, end, StandardCharsets.UTF_8)
            }
            val result = "${base}_test_${ts}_$suffix"
            check(result.toByteArray(StandardCharsets.UTF_8).size <= MAX_NAME_LEN) {
                "pgdesign testdb: database name exceeds 63 bytes: $result"
            }
            return result
        }

        private fun randomString(n: Int): String {
            val sb = StringBuilder(n)
            repeat(n) {
                sb.append(CHARSET[RANDOM.nextInt(CHARSET.length)])
            }
            return sb.toString()
        }

        private fun swapDB(connUrl: String, dbName: String): String {
            val uri = URI.create(connUrl)
            return URI(
                uri.scheme, uri.userInfo, uri.host,
                uri.port, "/$dbName", uri.query, null
            ).toString()
        }

        /**
         * Convert a postgres:// URL to a jdbc:postgresql:// URL.
         * JDBC requires the jdbc: prefix; pg connection URLs typically use postgres://.
         */
        private fun toJdbcUrl(pgUrl: String): String = when {
            pgUrl.startsWith("jdbc:") -> pgUrl
            pgUrl.startsWith("postgres://") ->
                "jdbc:postgresql://" + pgUrl.removePrefix("postgres://")
            pgUrl.startsWith("postgresql://") ->
                "jdbc:postgresql://" + pgUrl.removePrefix("postgresql://")
            else -> "jdbc:$pgUrl"
        }

        /**
         * Escape a PostgreSQL identifier by double-quoting it.
         * Internal double quotes are doubled per SQL standard.
         */
        private fun escapeIdentifier(name: String): String =
            "\"${name.replace("\"", "\"\"")}\""

        /**
         * Parse the .sqlsplit format: count line, then (byte-length, payload, newline) per stmt.
         */
        private fun parseSQLSplit(data: ByteArray): List<String> {
            var pos = 0

            // Read statement count line.
            val nl = data.indexOf('\n'.code.toByte(), pos)
            require(nl >= 0) { "pgdesign testdb: missing statement count line in $DDL_PATH" }
            val count = String(data, pos, nl - pos, StandardCharsets.UTF_8).trim().toInt()
            pos = nl + 1

            val stmts = mutableListOf<String>()
            for (i in 0 until count) {
                // Read byte-length line.
                val lenNl = data.indexOf('\n'.code.toByte(), pos)
                require(lenNl >= 0) {
                    "pgdesign testdb: statement $i: missing length line in $DDL_PATH"
                }
                val length = String(data, pos, lenNl - pos, StandardCharsets.UTF_8).trim().toInt()
                pos = lenNl + 1

                // Read exactly `length` bytes.
                stmts.add(String(data, pos, length, StandardCharsets.UTF_8))
                pos += length

                // Skip trailing newline.
                if (pos < data.size && data[pos] == '\n'.code.toByte()) {
                    pos++
                }
            }
            return stmts
        }

        /** Extension: find byte in array starting at offset. */
        private fun ByteArray.indexOf(b: Byte, from: Int): Int {
            for (i in from until size) {
                if (this[i] == b) return i
            }
            return -1
        }

        private fun applyDDL(conn: Connection) {
            val data = Files.readAllBytes(Paths.get(DDL_PATH))
            val stmts = parseSQLSplit(data)
            conn.createStatement().use { st ->
                stmts.forEachIndexed { i, sql ->
                    try {
                        st.execute(sql)
                    } catch (e: java.sql.SQLException) {
                        var preview = sql.trim().lines().toList()
                            .firstOrNull { it.trim().isNotEmpty() }?.trim() ?: ""
                        if (preview.length > 120) {
                            preview = preview.take(120) + "..."
                        }
                        throw java.sql.SQLException(
                            "pgdesign testdb: statement ${i + 1} failed ($preview): ${e.message}", e
                        )
                    }
                }
            }
        }

        private fun dropDB(connUrl: String, dbName: String) {
            validateName(dbName)
            val maintUrl = swapDB(connUrl, "postgres")
            try {
                DriverManager.getConnection(toJdbcUrl(maintUrl)).use { conn ->
                    conn.autoCommit = true
                    conn.prepareStatement(
                        "SELECT pg_terminate_backend(pid) FROM pg_stat_activity " +
                        "WHERE datname = ? AND pid != pg_backend_pid()"
                    ).use { ps ->
                        ps.setString(1, dbName)
                        ps.execute()
                    }
                    conn.createStatement().use { stmt ->
                        stmt.execute("DROP DATABASE IF EXISTS ${escapeIdentifier(dbName)}")
                    }
                }
            } catch (_: java.sql.SQLException) {
                // Best-effort cleanup.
            }
        }
    }
}
