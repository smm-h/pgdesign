// pgdesign testdb protocol v1
// Generated by pgdesign -- do not edit manually. Re-run: pgdesign testdb init --language typescript
import { Client } from "pg";
import { readFileSync } from "fs";
import { randomFillSync } from "crypto";
import { parse as parseUrl, format as formatUrl, UrlWithStringQuery } from "url";

const DDL_PATH = "{{DDL_PATH}}";
const BASE_URL = "{{BASE_URL}}";
const BASE_NAME = "{{BASE_NAME}}";
const CHARSET = "abcdefghijklmnopqrstuvwxyz0123456789";

export interface TestDB {
  client: Client;
  url: string;
  name: string;
  teardown: () => Promise<void>;
}

function generateName(): string {
  // Rejection sampling: discard bytes >= 252 to avoid modulo bias
  // (256 % 36 = 4, so floor(256/36) * 36 = 252).
  const suffix: string[] = [];
  const buf = Buffer.alloc(1);
  for (let i = 0; i < 8; i++) {
    let b: number;
    do {
      randomFillSync(buf);
      b = buf[0];
    } while (b >= 252);
    suffix.push(CHARSET[b % CHARSET.length]);
  }
  const ts = Math.floor(Date.now() / 1000);
  // Fixed suffix: _test_ (6) + timestamp (10) + _ (1) + random (8) = 25
  const maxBase = 63 - 25;
  let base = BASE_NAME;
  if (Buffer.byteLength(base) > maxBase) {
    base = base.substring(0, maxBase);
  }
  const name = `${base}_test_${ts}_${suffix.join("")}`;
  if (Buffer.byteLength(name) > 63) {
    throw new Error(`pgdesign testdb: database name exceeds 63 bytes: ${name}`);
  }
  return name;
}

function swapDB(connUrl: string, dbName: string): string {
  const parsed = parseUrl(connUrl);
  const swapped: UrlWithStringQuery = {
    ...parsed,
    pathname: "/" + dbName,
  };
  return formatUrl(swapped);
}

function escapeIdentifier(name: string): string {
  return '"' + name.replace(/"/g, '""') + '"';
}

async function applyDDL(client: Client): Promise<void> {
  const data = readFileSync(DDL_PATH, "utf-8");
  const stmts: string[] = JSON.parse(data);
  for (let i = 0; i < stmts.length; i++) {
    try {
      await client.query(stmts[i]);
    } catch (err) {
      throw new Error(
        `pgdesign testdb: statement ${i + 1} failed: ${err instanceof Error ? err.message : err}`
      );
    }
  }
}

async function dropDB(baseUrl: string, name: string): Promise<void> {
  const maintUrl = swapDB(baseUrl, "postgres");
  const client = new Client({ connectionString: maintUrl });
  try {
    await client.connect();
    await client.query(
      "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = $1 AND pid != pg_backend_pid()",
      [name]
    );
    await client.query(`DROP DATABASE IF EXISTS ${escapeIdentifier(name)}`);
  } catch {
    // Best-effort cleanup.
  } finally {
    await client.end().catch(() => {});
  }
}

/**
 * Create an ephemeral test database, apply DDL, and return a connected client.
 * Call teardown() when done to drop the database.
 */
export async function setupTestDB(): Promise<TestDB> {
  const name = generateName();
  const baseUrl = process.env.PGDESIGN_DB || BASE_URL;
  const maintUrl = swapDB(baseUrl, "postgres");

  // Create the ephemeral database.
  const maintClient = new Client({ connectionString: maintUrl });
  await maintClient.connect();
  try {
    await maintClient.query(`CREATE DATABASE ${escapeIdentifier(name)}`);
  } finally {
    await maintClient.end();
  }

  // Connect to the new database and apply DDL.
  const dbUrl = swapDB(baseUrl, name);
  const client = new Client({ connectionString: dbUrl });
  try {
    await client.connect();
    await applyDDL(client);
  } catch (err) {
    await client.end().catch(() => {});
    await dropDB(baseUrl, name);
    throw err;
  }

  const teardown = async (): Promise<void> => {
    await client.end().catch(() => {});
    await dropDB(baseUrl, name);
  };

  return { client, url: dbUrl, name, teardown };
}

/**
 * Jest/Vitest helper: set up before all tests, tear down after.
 *
 * Usage:
 *   const { getTestDB } = useTestDB();
 *   test("example", async () => { const db = getTestDB(); ... });
 */
export function useTestDB(): { getTestDB: () => TestDB } {
  let db: TestDB | undefined;

  beforeAll(async () => {
    db = await setupTestDB();
  });

  afterAll(async () => {
    if (db) {
      await db.teardown();
    }
  });

  return {
    getTestDB: () => {
      if (!db) {
        throw new Error("pgdesign testdb: setupTestDB has not completed yet");
      }
      return db;
    },
  };
}
