# Generated by pgdesign -- do not edit manually. Re-run: pgdesign testdb init --ci github-actions
name: pgdesign testdb

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  PGDESIGN_DB: postgres://test:test@localhost:5432/postgres

jobs:
  test:
    runs-on: ubuntu-latest
    strategy:
      matrix:
        language: [{{LANGUAGES}}]

    services:
      postgres:
        image: postgres:{{PG_VERSION}}
        env:
          POSTGRES_USER: test
          POSTGRES_PASSWORD: test
          POSTGRES_DB: postgres
        ports:
          - 5432:5432
        options: >-
          --health-cmd "pg_isready -U test"
          --health-interval 10s
          --health-timeout 5s
          --health-retries 5

    steps:
      - uses: actions/checkout@v4

      - name: Setup Go
        if: matrix.language == 'go'
        uses: actions/setup-go@v5
        with:
          go-version-file: go.mod

      - name: Setup Python
        if: matrix.language == 'python'
        uses: actions/setup-python@v5
        with:
          python-version: '3.x'

      - name: Install Python dependencies
        if: matrix.language == 'python'
        run: pip install psycopg pytest

      - name: Setup Node.js
        if: matrix.language == 'ts'
        uses: actions/setup-node@v4
        with:
          node-version: 'lts/*'

      - name: Install Node.js dependencies
        if: matrix.language == 'ts'
        run: npm install

      - name: Setup Java
        if: matrix.language == 'java' || matrix.language == 'kotlin'
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '21'

      - name: Setup Zig
        if: matrix.language == 'zig'
        uses: mlugg/setup-zig@v2

      - name: Test (Go)
        if: matrix.language == 'go'
        run: go test ./... -race

      - name: Test (Python)
        if: matrix.language == 'python'
        run: pytest

      - name: Test (TypeScript)
        if: matrix.language == 'ts'
        run: npm test

      - name: Test (Java)
        if: matrix.language == 'java'
        run: gradle test

      - name: Test (Kotlin)
        if: matrix.language == 'kotlin'
        run: gradle test

      - name: Test (Zig)
        if: matrix.language == 'zig'
        run: zig build test
