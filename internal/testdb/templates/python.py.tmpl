# Generated by pgdesign -- do not edit manually. Re-run: pgdesign testdb init --language python
import os
import re
import secrets
import string
import time
from pathlib import Path
from urllib.parse import urlparse, urlunparse

import psycopg
from psycopg import sql
import pytest

DDL_PATH = "{{DDL_PATH}}"
BASE_URL = "{{BASE_URL}}"
BASE_NAME = "{{BASE_NAME}}"
CHARSET = string.ascii_lowercase + string.digits

_NAME_PATTERN = re.compile(r"^(.+)_test_(\d{10,})_([a-z0-9]{8})$")


def _validate_name(name):
    """Hard error if name does not match the ephemeral name pattern."""
    if not _NAME_PATTERN.match(name):
        raise RuntimeError(
            f"pgdesign: refusing to use database {name!r}: "
            "does not match ephemeral name pattern"
        )


class PgDesignTestDB:
    """Opaque handle to an ephemeral test database."""

    def __init__(self, conn, name, url):
        _validate_name(name)
        self._conn = conn
        self._name = name
        self._url = url

    @property
    def conn(self):
        """Read-only access to the database connection."""
        return self._conn

    def conn_string(self):
        """Return the connection URL for ORM integration."""
        return self._url

    def with_raw_conn(self, callback):
        """Call callback with the underlying connection."""
        return callback(self._conn)


def _generate_name():
    """Create a unique ephemeral database name."""
    suffix = "".join(secrets.choice(CHARSET) for _ in range(8))
    ts = int(time.time())
    # Fixed suffix: _test_ (6) + timestamp (10) + _ (1) + random (8) = 25
    max_base = 63 - 25
    base = BASE_NAME
    if len(base.encode("utf-8")) > max_base:
        # Truncate by bytes at a valid UTF-8 boundary: encode to bytes,
        # slice at the byte limit, decode back dropping any partial character.
        base = base.encode("utf-8")[:max_base].decode("utf-8", errors="ignore")
    name = f"{base}_test_{ts}_{suffix}"
    if len(name.encode()) > 63:
        raise ValueError(f"database name exceeds 63 bytes: {name}")
    return name


def _swap_db(conn_url, db_name):
    """Rewrite a PostgreSQL connection URL to target a different database."""
    parsed = urlparse(conn_url)
    replaced = parsed._replace(path="/" + db_name)
    return urlunparse(replaced)


def _parse_sqlsplit(data):
    """Parse the .sqlsplit format: count line, then (byte-length, payload, newline) per stmt."""
    raw = data.encode("utf-8") if isinstance(data, str) else data
    pos = 0

    # Read statement count.
    nl = raw.index(b"\n", pos)
    count = int(raw[pos:nl])
    pos = nl + 1

    stmts = []
    for i in range(count):
        # Read byte-length line.
        nl = raw.index(b"\n", pos)
        length = int(raw[pos:nl])
        pos = nl + 1

        # Read exactly `length` bytes.
        stmts.append(raw[pos : pos + length].decode("utf-8"))
        pos += length

        # Skip trailing newline.
        if pos < len(raw) and raw[pos : pos + 1] == b"\n":
            pos += 1

    return stmts


def _apply_ddl(db_url):
    """Read the .sqlsplit file and execute each SQL statement."""
    ddl_file = Path(DDL_PATH)
    data = ddl_file.read_bytes()
    stmts = _parse_sqlsplit(data)
    with psycopg.connect(db_url) as conn:
        for i, stmt in enumerate(stmts):
            try:
                conn.execute(stmt)
            except Exception as exc:
                first_line = next(
                    (l for l in stmt.split("\n") if l.strip()), ""
                ).strip()
                if len(first_line) > 120:
                    first_line = first_line[:120] + "..."
                raise RuntimeError(
                    f"pgdesign testdb: statement {i + 1} failed ({first_line}): {exc}"
                ) from exc
        conn.commit()


def _drop_db(base_url, name):
    """Terminate connections and drop the named database."""
    _validate_name(name)
    maint_url = _swap_db(base_url, "postgres")
    try:
        with psycopg.connect(maint_url, autocommit=True) as conn:
            conn.execute(
                "SELECT pg_terminate_backend(pid) "
                "FROM pg_stat_activity "
                "WHERE datname = %s AND pid != pg_backend_pid()",
                (name,),
            )
            conn.execute(
                sql.SQL("DROP DATABASE IF EXISTS {}").format(sql.Identifier(name))
            )
    except Exception:
        pass


