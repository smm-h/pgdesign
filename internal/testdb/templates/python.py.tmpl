# pgdesign testdb protocol v1
# Generated by pgdesign -- do not edit manually. Re-run: pgdesign testdb init --language python
import json
import os
import secrets
import string
import time
from pathlib import Path
from urllib.parse import urlparse, urlunparse

import psycopg
from psycopg import sql
import pytest

DDL_PATH = "{{DDL_PATH}}"
BASE_URL = "{{BASE_URL}}"
BASE_NAME = "{{BASE_NAME}}"
CHARSET = string.ascii_lowercase + string.digits


def _generate_name():
    """Create a unique ephemeral database name."""
    suffix = "".join(secrets.choice(CHARSET) for _ in range(8))
    ts = int(time.time())
    # Fixed suffix: _test_ (6) + timestamp (10) + _ (1) + random (8) = 25
    max_base = 63 - 25
    base = BASE_NAME
    if len(base.encode("utf-8")) > max_base:
        # Truncate by bytes at a valid UTF-8 boundary: encode to bytes,
        # slice at the byte limit, decode back dropping any partial character.
        base = base.encode("utf-8")[:max_base].decode("utf-8", errors="ignore")
    name = f"{base}_test_{ts}_{suffix}"
    if len(name.encode()) > 63:
        raise ValueError(f"database name exceeds 63 bytes: {name}")
    return name


def _swap_db(conn_url, db_name):
    """Rewrite a PostgreSQL connection URL to target a different database."""
    parsed = urlparse(conn_url)
    replaced = parsed._replace(path="/" + db_name)
    return urlunparse(replaced)


def _apply_ddl(db_url):
    """Read the .split.json file and execute each SQL statement."""
    ddl_file = Path(DDL_PATH)
    data = json.loads(ddl_file.read_text(encoding="utf-8"))
    stmts = data["statements"]
    with psycopg.connect(db_url) as conn:
        for i, stmt in enumerate(stmts):
            try:
                conn.execute(stmt)
            except Exception as exc:
                first_line = next(
                    (l for l in stmt.split("\n") if l.strip()), ""
                ).strip()
                if len(first_line) > 120:
                    first_line = first_line[:120] + "..."
                raise RuntimeError(
                    f"pgdesign testdb: statement {i + 1} failed ({first_line}): {exc}"
                ) from exc
        conn.commit()


def _drop_db(base_url, name):
    """Terminate connections and drop the named database."""
    maint_url = _swap_db(base_url, "postgres")
    try:
        with psycopg.connect(maint_url, autocommit=True) as conn:
            conn.execute(
                "SELECT pg_terminate_backend(pid) "
                "FROM pg_stat_activity "
                "WHERE datname = %s AND pid != pg_backend_pid()",
                (name,),
            )
            conn.execute(
                sql.SQL("DROP DATABASE IF EXISTS {}").format(sql.Identifier(name))
            )
    except Exception:
        pass


@pytest.fixture(scope="session")
def pgdesign_db():
    """Create an ephemeral test database, yield a connection, drop on teardown."""
    name = _generate_name()
    base_url = os.environ.get("PGDESIGN_DB", BASE_URL)
    maint_url = _swap_db(base_url, "postgres")

    # Create database (autocommit required for CREATE DATABASE).
    with psycopg.connect(maint_url, autocommit=True) as conn:
        conn.execute(
            sql.SQL("CREATE DATABASE {}").format(sql.Identifier(name))
        )

    # Apply DDL.
    db_url = _swap_db(base_url, name)
    try:
        _apply_ddl(db_url)
    except Exception:
        _drop_db(base_url, name)
        raise

    # Yield connection for tests.
    conn = psycopg.connect(db_url)
    try:
        yield conn
    finally:
        conn.close()
        _drop_db(base_url, name)


