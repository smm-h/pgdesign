{
  "targets": [
    "go",
    {
      "name": "npm",
      "path": "npm/"
    },
    {
      "name": "pypi",
      "path": "pypi/"
    }
  ],
  "pipelines": {
    "go": {
      "type": "go",
      "local": true
    },
    "npm": {
      "type": "npm",
      "local": false
    },
    "pypi": {
      "type": "pypi",
      "local": false
    }
  },
  "private": false,
  "push_timeout": 120,
  "batch_limits": {
    "exclusions": [
      {
        "reason": "non-user-facing batch",
        "entries": [
          {
            "version": "unreleased",
            "line": 15
          }
        ]
      },
      {
        "reason": "non-user-facing batch",
        "entries": [
          {
            "version": "unreleased",
            "line": 16
          }
        ]
      }
    ]
  }
}
