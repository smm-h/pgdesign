{
  "targets": [
    "go",
    {
      "name": "npm",
      "path": "npm/"
    },
    {
      "name": "pypi",
      "path": "pypi/"
    }
  ],
  "pipelines": {
    "go": {
      "type": "go",
      "local": true,
      "install_paths": [
        "./cmd/pgdesign"
      ]
    },
    "npm": {
      "type": "npm",
      "local": false
    },
    "pypi": {
      "type": "pypi",
      "local": false
    }
  },
  "private": false,
  "push_timeout": 120,
  "batch_limits": {
    "exclusions": []
  },
  "coverage_unit": "commit"
}
